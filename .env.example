# ============================================================================
# Friends Factory Cafe — Environment Variables
# Copy this to .env.local and fill in the values
# ============================================================================

# ── Google Indexing API ─────────────────────────────────────────────────────
# Required for: /api/indexing/*, /api/reindex, scripts/batch-index.ts
# Setup guide: https://developers.google.com/search/apis/indexing-api/v3/prereqs
#
# Step 1: Go to Google Cloud Console (console.cloud.google.com)
# Step 2: Create a new project (or select existing)
# Step 3: Enable "Web Search Indexing API"
# Step 4: Go to IAM & Admin → Service Accounts → Create Service Account
# Step 5: Create a key (JSON type) → Download the JSON file
# Step 6: Copy the "client_email" to GOOGLE_SERVICE_ACCOUNT_EMAIL
# Step 7: Copy the "private_key" to GOOGLE_PRIVATE_KEY
# Step 8: Go to Google Search Console → Settings → Users and permissions
# Step 9: Add the service account email as an OWNER
#
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── API Authentication Keys ────────────────────────────────────────────────
# These protect your indexing API routes from unauthorized access.
# Generate strong random strings (e.g., openssl rand -hex 32)
#
INDEXING_API_KEY=your-random-api-key-for-indexing-routes
REINDEX_API_KEY=your-random-api-key-for-reindex-route

# ── Existing Keys (already configured) ─────────────────────────────────────
# META_PIXEL_ID=2357920771285041
# Google Search Console verification is in layout.tsx metadata
